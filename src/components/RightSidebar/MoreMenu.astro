---
import ThemeToggleButton from './ThemeToggleButton';
import Icon from '../Icon.astro';
import * as CONFIG from '../../config';

type Props = {
	editHref: string;
};

const { editHref } = Astro.props as Props;

const links = [
	{ href: editHref, icon: 'pencil', label: 'Edit this page' },
	{ href: CONFIG.GITHUB_REPO_URL, icon: 'github', label: 'Star on GitHub' },
	{ href: CONFIG.PATREON_URL, icon: 'heart', label: 'Support on Patreon' },
] as const;
---

<h2 class="heading">More</h2>
<ul>
	{
		links.map((l) => (
			<li class="heading-link depth-2">
				<a href={l.href} target="_blank" rel="noopener noreferrer">
					<Icon name={l.icon} size={16} />
					<span>{l.label}</span>
				</a>
			</li>
		))
	}
</ul>
<div class="theme-toggle-wrap">
	<span class="toggle-label">Theme</span>
	<ThemeToggleButton client:visible />
</div>

<style>
	.heading-link a {
		display: inline-flex;
		align-items: center;
		gap: 0.6em;
	}
	.heading-link :global(svg) {
		flex-shrink: 0;
	}
	.theme-toggle-wrap {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin: 2rem 0 0;
		padding: 0 0.75rem;
	}
	.toggle-label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--theme-text-lighter);
	}
</style>
