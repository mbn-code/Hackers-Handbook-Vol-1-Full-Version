---
// Offline, static full-text search powered by Pagefind.
// The index (/pagefind/*) is generated at build time by `pagefind --site dist`
// (see the `build` script). During `astro dev` the index does not exist yet, so
// the modal shows a short "run a production build" hint instead of crashing.
---

<button
	type="button"
	id="search-button"
	class="search-input"
	aria-label="Search the handbook"
	aria-keyshortcuts="/"
>
	<svg width="18" height="18" fill="none" aria-hidden="true">
		<path
			d="M17 17l-4.5-4.5m1.5-4a5.5 5.5 0 11-11 0 5.5 5.5 0 0111 0z"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"></path>
	</svg>
	<span class="search-label">Search</span>
	<span class="search-hint"><kbd>/</kbd></span>
</button>

<div id="search-modal" class="search-modal" hidden>
	<div class="search-backdrop" data-search-close></div>
	<div class="search-dialog" role="dialog" aria-modal="true" aria-label="Search">
		<div class="search-dialog-head">
			<span class="search-dialog-title">Search the handbook</span>
			<button type="button" class="search-close" data-search-close aria-label="Close search">
				<kbd>Esc</kbd>
			</button>
		</div>
		<div id="pagefind-search"></div>
		<p class="search-dev-hint" hidden>
			Search index isn't available in dev mode. Run <code>npm run build &amp;&amp; npm run preview</code> to try it.
		</p>
	</div>
</div>

<style>
	.search-input {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		width: 100%;
		max-width: 15rem;
		padding: 0.45rem 0.8rem;
		color: var(--theme-text-light);
		background: var(--theme-bg-hover);
		border: 1px solid var(--theme-divider);
		border-radius: 0.6rem;
		font-size: 0.9rem;
		cursor: pointer;
		transition: border-color 0.15s ease, color 0.15s ease;
	}

	.search-input:hover,
	.search-input:focus-visible {
		color: var(--theme-text);
		border-color: var(--theme-accent);
	}

	.search-label {
		flex: 1;
		text-align: left;
	}

	.search-hint kbd,
	.search-close kbd {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		padding: 0.05rem 0.4rem;
		border: 1px solid var(--theme-divider);
		border-radius: 0.3rem;
		background: var(--theme-bg);
		color: var(--theme-text-lighter);
	}

	.search-modal {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: max(3rem, 8vh) 1rem 1rem;
	}

	.search-modal[hidden] {
		display: none;
	}

	.search-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(2, 6, 12, 0.6);
		backdrop-filter: blur(3px);
	}

	.search-dialog {
		position: relative;
		width: min(40rem, 100%);
		max-height: 80vh;
		display: flex;
		flex-direction: column;
		background: var(--theme-bg);
		border: 1px solid var(--theme-divider);
		border-radius: 0.9rem;
		box-shadow: var(--theme-glow);
		overflow: hidden;
		animation: search-in 0.15s ease-out;
	}

	@keyframes search-in {
		from {
			opacity: 0;
			transform: translateY(-0.5rem);
		}
	}

	.search-dialog-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem;
		border-bottom: 1px solid var(--theme-divider);
	}

	.search-dialog-title {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--theme-text-lighter);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.search-close {
		display: inline-flex;
	}

	#pagefind-search {
		padding: 1rem;
		overflow-y: auto;

		--pagefind-ui-scale: 0.9;
		--pagefind-ui-primary: var(--theme-accent);
		--pagefind-ui-text: var(--theme-text);
		--pagefind-ui-background: var(--theme-bg);
		--pagefind-ui-border: var(--theme-divider);
		--pagefind-ui-tag: var(--theme-bg-hover);
		--pagefind-ui-border-width: 1px;
		--pagefind-ui-border-radius: 0.6rem;
		--pagefind-ui-font: var(--font-body);
	}

	.search-dev-hint {
		margin: 0;
		padding: 0 1rem 1rem;
		font-size: 0.85rem;
		color: var(--theme-text-lighter);
	}

	@media (max-width: 50em) {
		.search-label,
		.search-hint {
			display: none;
		}
		.search-input {
			max-width: none;
			width: auto;
			justify-content: center;
		}
	}
</style>

<!--
  Inlined (is:inline) so Vite does not try to bundle the runtime-only
  `/pagefind/*` assets, which are generated after the Astro build finishes.
-->
<script is:inline>
	(function () {
		var button = document.getElementById('search-button');
		var modal = document.getElementById('search-modal');
		var container = document.getElementById('pagefind-search');
		var devHint = document.querySelector('.search-dev-hint');
		var initialised = false;

		function showDevHint() {
			initialised = false;
			if (container) container.setAttribute('hidden', '');
			if (devHint) devHint.removeAttribute('hidden');
		}

		function initPagefind() {
			if (initialised) return;
			initialised = true;

			if (!document.getElementById('pagefind-ui-css')) {
				var link = document.createElement('link');
				link.id = 'pagefind-ui-css';
				link.rel = 'stylesheet';
				link.href = '/pagefind/pagefind-ui.css';
				document.head.appendChild(link);
			}

			if (window.PagefindUI) {
				mount();
				return;
			}

			var script = document.createElement('script');
			script.src = '/pagefind/pagefind-ui.js';
			script.onload = mount;
			script.onerror = showDevHint;
			document.head.appendChild(script);
		}

		function mount() {
			try {
				new window.PagefindUI({
					element: '#pagefind-search',
					showSubResults: true,
					showImages: false,
					resetStyles: false,
				});
			} catch (err) {
				showDevHint();
				console.warn('[search] Pagefind index not available (expected in dev).', err);
			}
		}

		function openSearch() {
			if (!modal) return;
			modal.removeAttribute('hidden');
			document.body.style.overflow = 'hidden';
			initPagefind();
			requestAnimationFrame(function () {
				var input = modal.querySelector('input[type="text"]');
				if (input) input.focus();
			});
		}

		function closeSearch() {
			if (!modal) return;
			modal.setAttribute('hidden', '');
			document.body.style.overflow = '';
			if (button) button.focus();
		}

		if (button) button.addEventListener('click', openSearch);
		if (modal) {
			var closers = modal.querySelectorAll('[data-search-close]');
			for (var i = 0; i < closers.length; i++) {
				closers[i].addEventListener('click', closeSearch);
			}
		}

		document.addEventListener('keydown', function (e) {
			var isOpen = modal && !modal.hasAttribute('hidden');
			var target = e.target;
			var typing =
				target && (/^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName) || target.isContentEditable);

			if (e.key === 'Escape' && isOpen) {
				e.preventDefault();
				closeSearch();
			} else if (
				(e.key === '/' && !typing && !isOpen) ||
				((e.metaKey || e.ctrlKey) && e.key === 'k')
			) {
				e.preventDefault();
				openSearch();
			}
		});
	})();
</script>
