---
import { getLanguageFromURL } from '../../languages';
import { SIDEBAR } from '../../config';
import Icon from '../Icon.astro';

type Props = {
	currentPage: string;
};

const { currentPage } = Astro.props as Props;
// Normalise the leading slash and any trailing slash so the comparison against
// the (slash-less) sidebar links matches on directory-format URLs.
const currentPageMatch = currentPage.slice(1).replace(/\/$/, '');
const langCode = getLanguageFromURL(currentPage);
const sidebar = SIDEBAR[langCode];

// Section → icon, so each group is recognisable at a glance.
const GROUP_ICONS: Record<string, string> = {
	'Getting Started': 'compass',
	Fundamentals: 'cpu',
	'Tools & Techniques': 'wrench',
	'Advanced Topics': 'layers',
	Glossary: 'list',
};
---

<nav aria-labelledby="grid-left">
	<ul class="nav-groups">
		{
			Object.entries(sidebar).map(([header, children]) => (
				<li>
					<div class="nav-group">
						<h2 class="nav-group-title">
							<Icon name={(GROUP_ICONS[header] as any) ?? 'book-open'} size={15} />
							<span>{header}</span>
						</h2>
						<ul>
							{children.map((child) => {
								const url = Astro.site?.pathname + child.link;
								return (
									<li class="nav-link">
										<a href={url} aria-current={currentPageMatch === child.link ? 'page' : false}>
											{child.text}
										</a>
									</li>
								);
							})}
						</ul>
					</div>
				</li>
			))
		}
	</ul>
</nav>

<script is:inline>
	window.addEventListener('DOMContentLoaded', () => {
		const target = document.querySelector('[aria-current="page"]');
		const nav = document.querySelector('.nav-groups');
		// Scroll the active link into view only when it's below the fold.
		if (target && nav && target.offsetTop > window.innerHeight) {
			nav.scrollTop = target.offsetTop;
		}
	});
</script>

<style>
	nav {
		width: 100%;
		margin-right: 1rem;
	}

	.nav-groups {
		height: 100%;
		padding: 2rem 0;
		overflow-x: visible;
		overflow-y: auto;
		max-height: 100vh;
	}

	.nav-groups > li + li {
		margin-top: 1.75rem;
	}

	.nav-groups > :first-child {
		padding-top: var(--doc-padding);
	}

	.nav-groups > :last-child {
		padding-bottom: 2rem;
		margin-bottom: var(--theme-navbar-height);
	}

	.nav-group-title {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--theme-text-lighter);
		padding: 0 0.75rem;
		margin: 0 0 0.6rem;
		line-height: 1.3;
	}

	.nav-group-title :global(svg) {
		flex-shrink: 0;
		color: var(--theme-text-accent);
		opacity: 0.85;
	}

	.nav-group ul {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}

	.nav-link a {
		position: relative;
		font-size: 0.92rem;
		font-weight: 500;
		padding: 0.4rem 0.75rem;
		color: var(--theme-text-light);
		text-decoration: none;
		display: block;
		border-radius: var(--radius-sm);
		transition: color 0.12s ease, background 0.12s ease;
	}

	.nav-link a:hover,
	.nav-link a:focus-visible {
		color: var(--theme-text);
		background-color: var(--theme-bg-hover);
	}

	.nav-link a[aria-current='page'] {
		color: var(--theme-text-accent);
		background-color: var(--theme-bg-accent);
		font-weight: 600;
	}

	.nav-link a[aria-current='page']::before {
		content: '';
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		height: 1.1em;
		width: 3px;
		border-radius: 0 3px 3px 0;
		background: var(--theme-accent);
	}

	@media (min-width: 50em) {
		.nav-groups {
			padding: 0;
		}
	}
</style>

<style is:global>
	:root.theme-dark .nav-link a[aria-current='page'] {
		color: var(--theme-text-accent);
	}
</style>
